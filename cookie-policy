<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rheoa RPG – Cookie Policy</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Courier New', monospace;
      background: #f8f8f0;
      color: #222;
      padding: 28px 20px;
      min-height: 100vh;
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      background: white;
      border: 3px solid black;
      border-radius: 16px;
      padding: 40px 35px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
    }

    h1 {
      font-size: 2.4rem;
      margin-bottom: 6px;
      color: #1a4b7a;
      letter-spacing: -1px;
      border-bottom: 4px solid #2c6e9e;
      padding-bottom: 12px;
    }

    .subhead {
      color: #555;
      font-style: italic;
      margin-bottom: 30px;
      font-size: 1.05rem;
    }

    h2 {
      font-size: 1.6rem;
      margin: 36px 0 16px;
      color: #1e2f5e;
      border-left: 6px solid #2c6e9e;
      padding-left: 16px;
    }

    h3 {
      font-size: 1.2rem;
      margin: 24px 0 10px;
      color: #1f5480;
    }

    p, li {
      margin-bottom: 14px;
      color: #1e1e1e;
    }

    ul {
      padding-left: 28px;
      margin: 10px 0 20px;
    }

    ul li {
      margin-bottom: 8px;
      list-style-type: '🍪 ';
      padding-left: 6px;
    }

    ul li::marker {
      font-size: 1.1rem;
    }

    .highlight-box {
      background: #f0f4fa;
      border-left: 4px solid #2c6e9e;
      padding: 16px 22px;
      margin: 24px 0;
      border-radius: 6px;
      font-size: 0.95rem;
    }

    .highlight-box strong {
      color: #1a4b7a;
    }

    .badge {
      display: inline-block;
      background: #1e2f5e;
      color: white;
      padding: 2px 14px;
      border-radius: 40px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-right: 8px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 18px 0 24px;
      font-size: 0.95rem;
    }

    th {
      background: #1e2f5e;
      color: white;
      padding: 10px 12px;
      text-align: left;
      font-weight: 600;
    }

    td {
      padding: 10px 12px;
      border-bottom: 1px solid #ddd;
      vertical-align: top;
    }

    tr:nth-child(even) {
      background: #f8fafc;
    }

    .back-button {
      display: inline-block;
      margin-top: 40px;
      padding: 12px 32px;
      font-family: 'Courier New', monospace;
      font-weight: bold;
      border: 2px solid black;
      border-radius: 8px;
      background: #666;
      color: white;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      font-size: 1rem;
    }

    .back-button:hover {
      background: #222;
      transform: scale(1.02);
    }

    .footer-meta {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 2px dashed #ccc;
      font-size: 0.85rem;
      color: #666;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }

    .footer-meta a {
      color: #1f5480;
      text-decoration: none;
    }

    .footer-meta a:hover {
      text-decoration: underline;
    }

    @media (max-width: 600px) {
      body { padding: 16px; }
      .container { padding: 24px 18px; }
      h1 { font-size: 1.8rem; }
      h2 { font-size: 1.3rem; }
      table, td, th { font-size: 0.85rem; }
      .back-button { width: 100%; text-align: center; }
    }
  </style>
</head>
